// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROFESSOR
  ALUNO
  EXTERNO
}

model User {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name") @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  mustChangePassword Boolean @default(false) @map("must_change_password")
  role      Role     @default(EXTERNO)
  
  school    School?  @relation(fields: [schoolId], references: [id])
  schoolId  Int?     @map("school_id")
  
  themes    Theme[]
  rankingPoints Int  @default(0) @map("ranking_points")
  gameMatches   GameMatch[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum WinType {
  NORMAL
  CARROCA
  LAILOA
  LAILOA_CARROCA
  TRANCOU_MENOS
  TRANCOU_EMPATE
}

model GameMatch {
  id        String   @id @default(uuid())
  winnerId  String?  @map("winner_id") // Optional because guests won't tie to User
  winType   WinType  @map("win_type")
  points    Int
  roomId    String?  @map("room_id")
  
  winner    User?    @relation(fields: [winnerId], references: [id])
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("game_matches")
}

model School {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(255)
  inep      String?  @unique @db.VarChar(50)
  address   String?  @db.Text
  phone     String?  @db.VarChar(50)
  email     String?  @db.VarChar(100)
  cnpj      String?  @db.VarChar(50)
  director  String?  @db.VarChar(255)
  
  users     User[]
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("schools")
}

model Category {
  id         Int           @id @default(autoincrement())
  name       String        @unique @db.VarChar(255)
  isDefault  Boolean       @default(false) @map("is_default")
  isApproved Boolean       @default(true) @map("is_approved") // Default ones are approved
  themes     Theme[]
  subs       SubCategory[]
  createdAt  DateTime      @default(now()) @map("created_at")

  @@map("categories")
}

model SubCategory {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  isDefault  Boolean  @default(false) @map("is_default")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId Int      @map("category_id")
  themes     Theme[]
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("subcategories")
}

model Theme {
  id            String       @id @default(uuid())
  name          String       @db.VarChar(255)
  description   String?      @db.Text
  color         String       @default("#009660") @db.VarChar(50)
  isPublic      Boolean      @default(false) @map("is_public")
  isApproved    Boolean      @default(false) @map("is_approved") // Custom themes need approval
  
  owner         User?        @relation(fields: [ownerId], references: [id])
  ownerId       String?      @map("owner_id")
  
  // Array of 6 image URLs (for pieces 1-6, 0 is blank)
  symbols       String[]     @default([])
  
  summary       String?      @db.Text
  
  category      Category     @relation(fields: [categoryId], references: [id])
  categoryId    Int          @map("category_id")
  
  subcategory   SubCategory?  @relation(fields: [subcategoryId], references: [id])
  subcategoryId Int?         @map("subcategory_id")
  
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("themes")
}
