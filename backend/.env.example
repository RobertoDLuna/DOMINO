# ==============================
# Banco de Dados PostgreSQL
# ==============================
# Usado pelo Prisma ORM para conectar ao banco.
# Em produção (Docker Swarm), a senha vem da variável POSTGRES_PASSWORD do Swarm Secret.
#
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
#
# Desenvolvimento local (Postgres local):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/domino_db?schema=public"

# Desenvolvimento local (Postgres via Docker Compose):
# DATABASE_URL="postgresql://domino:domino@localhost:5432/domino_db?schema=public"

# Produção (Docker Swarm - preenchido automaticamente pelo docker-stack.yml):
# DATABASE_URL="postgresql://domino:${POSTGRES_PASSWORD}@postgres:5432/domino_db?schema=public"

# ==============================
# Ambiente
# ==============================
NODE_ENV=development
